{
    "compilerOptions": {
        "esModuleInterop": true,
        "target": "es2020",
        "module": "nodenext",
        "strict": true,
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "resolveJsonModule": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "noEmit": true,
        "lib": [
            "es2020"
        ],
        "incremental": false,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
    },
    "exclude": [
        "node_modules",
        ".dist"
    ]
}